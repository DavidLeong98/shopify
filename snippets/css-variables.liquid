{% comment %}
  Outputs CSS custom properties derived from theme settings.
  Used by password.liquid and gift_card.liquid layouts.
  Variable names match what theme.css expects.
{% endcomment %}

{% style %}
  :root {
    --font-heading: 'Playfair Display', serif;
    --font-body: 'Plus Jakarta Sans', sans-serif;
    --heading-font-scale: {{ settings.heading_font_scale | default: 100 | divided_by: 100.0 }};
    --body-font-scale: {{ settings.body_font_scale | default: 100 | divided_by: 100.0 }};
    --space-container-max: {{ settings.max_page_width | default: 1280 }}px;
    --space-section-gap: {{ settings.section_gap | default: 120 }}px;
    --space-gutter: {{ settings.gutter | default: 24 }}px;
  }
{% endstyle %}
