{% doc %}
  Renders a product card with image, badge overlay, quick-add button, and product info.

  @param {product} product - The product object to render
  @param {boolean} [show_quick_add] - Whether to show the quick-add button on hover (default: true)
{% enddoc %}

{% liquid
  assign show_quick_add = show_quick_add | default: true
%}

<div class="product-card">
  <a href="{{ product.url }}" class="product-card__image-container">
    {% if product.featured_image != blank %}
      {{ product.featured_image | image_url: width: 800 | image_tag: class: 'product-card__image', loading: 'lazy' }}
    {% endif %}

    {% if product.metafields.custom.badge != blank %}
      <span class="product-card__badge label-sm">{{ product.metafields.custom.badge }}</span>
    {% endif %}

    {% if show_quick_add %}
      <span class="product-card__quick-add label-sm">
        {{ 'products.quick_add' | t }} &mdash; {{ product.price | money }}
      </span>
    {% endif %}
  </a>

  <div class="product-card__info">
    {% if product.type != blank %}
      <span class="product-card__category label-sm">{{ product.type }}</span>
    {% endif %}

    <h4 class="product-card__title headline-md">
      <a href="{{ product.url }}">{{ product.title }}</a>
    </h4>

    <p class="product-card__subtitle body-md">
      {{ product.metafields.descriptors.subtitle.value | default: product.description | strip_html | truncate: 80 }}
    </p>
  </div>
</div>

{% stylesheet %}
  .product-card__image-container {
    position: relative;
    display: block;
    aspect-ratio: 3/4;
    overflow: hidden;
    background-color: var(--color-surface);
    margin-bottom: 16px;
  }

  .product-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 700ms ease;
  }

  .product-card__image-container:hover .product-card__image {
    transform: scale(1.05);
  }

  .product-card__badge {
    position: absolute;
    top: 16px;
    left: 16px;
    background-color: color-mix(in srgb, white 80%, transparent);
    backdrop-filter: blur(4px);
    padding: 4px 12px;
    z-index: 1;
  }

  .product-card__quick-add {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background-color: var(--color-primary);
    color: var(--color-on-primary);
    text-align: center;
    padding: 16px;
    transform: translateY(100%);
    transition: transform 400ms ease;
  }

  .product-card__image-container:hover .product-card__quick-add {
    transform: translateY(0);
  }

  .product-card__info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .product-card__category {
    text-transform: uppercase;
    color: var(--color-on-surface-variant);
    letter-spacing: 0.05em;
  }

  .product-card__title a {
    color: var(--color-on-background);
    text-decoration: none;
  }

  .product-card__subtitle {
    color: var(--color-on-surface-variant);
    margin: 0;
  }
{% endstylesheet %}
