<section class="pdp section-gap">
  <div class="pdp__inner container">
    <div class="pdp__grid">
      <div class="pdp__gallery">
        {% for image in product.images limit: 3 %}
          <div class="pdp__image-wrap {% if forloop.first %}pdp__image-wrap--hero{% endif %}">
            {% if forloop.first %}
              {{ image | image_url: width: 900 | image_tag: class: 'pdp__image', loading: 'eager' }}
            {% else %}
              {{ image | image_url: width: 900 | image_tag: class: 'pdp__image', loading: 'lazy' }}
            {% endif %}
          </div>
        {% endfor %}
      </div>

      <div class="pdp__details">
        <div class="pdp__meta">
          <span class="label-sm" style="color: var(--color-on-surface-variant);">{{ product.type }}</span>
          {% if product.metafields.reviews.rating.value != blank %}
            <div class="pdp__rating">
              {% assign rating = product.metafields.reviews.rating.value.rating | round: 1 %}
              {% for i in (1..5) %}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="{% if i <= rating %}currentColor{% else %}none{% endif %}" stroke="currentColor" stroke-width="1.5" style="color: var(--color-on-surface-variant);">
                  <path d="m12 2 3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2Z"/>
                </svg>
              {% endfor %}
            </div>
          {% endif %}
        </div>

        <h1 class="display-lg" style="margin-bottom: 16px;">{{ product.title }}</h1>

        {% if product.description != blank %}
          <p class="body-lg" style="color: var(--color-on-surface-variant); max-width: 480px; margin-bottom: 24px;">
            {{ product.description | strip_html | truncate: 200 }}
          </p>
        {% endif %}

        <div class="pdp__price" style="font-size: 28px; font-weight: 500; color: var(--color-primary); margin-bottom: 40px;">
          {{ product.selected_or_first_available_variant.price | money }}
          {% if product.compare_at_price > product.price %}
            <span style="text-decoration: line-through; opacity: 0.5; font-size: 18px; margin-left: 8px;">
              {{ product.compare_at_price | money }}
            </span>
          {% endif %}
        </div>

        {% form 'product', product, class: 'pdp__form' %}
          {% assign current_variant = product.selected_or_first_available_variant %}
          <input type="hidden" name="id" value="{{ current_variant.id }}">

          {% if product.variants.size > 1 %}
            <div class="pdp__variants">
              {% for option in product.options_with_values %}
                <div class="pdp__option">
                  <label class="label-sm" for="option-{{ option.name | handleize }}">{{ option.name }}</label>
                  <select id="option-{{ option.name | handleize }}" class="pdp__option-select" name="options[{{ option.name }}]">
                    {% for value in option.values %}
                      <option value="{{ value }}" {% if option.selected_value == value %}selected{% endif %}>
                        {{ value }}
                      </option>
                    {% endfor %}
                  </select>
                </div>
              {% endfor %}
            </div>
          {% endif %}

          <div class="pdp__add-section">
            <div class="pdp__quantity">
              <span class="label-sm" style="color: var(--color-on-surface-variant);">{{ 'products.quantity' | t }}</span>
              <div class="pdp__quantity-controls">
                <button type="button" class="pdp__qty-btn" aria-label="{{ 'products.decrease' | t }}" onclick="this.nextElementSibling.stepDown(); this.nextElementSibling.dispatchEvent(new Event('change'))">-</button>
                <input type="number" name="quantity" value="1" min="1" class="pdp__qty-input" aria-label="{{ 'products.quantity' | t }}">
                <button type="button" class="pdp__qty-btn" aria-label="{{ 'products.increase' | t }}" onclick="this.previousElementSibling.stepUp(); this.previousElementSibling.dispatchEvent(new Event('change'))">+</button>
              </div>
            </div>

            <button type="submit" class="btn-primary pdp__add-btn" {% unless current_variant.available %}disabled{% endunless %}>
              {% if current_variant.available %}
                {{ 'products.add_to_bag' | t }}
              {% else %}
                {{ 'products.sold_out' | t }}
              {% endif %}
            </button>

            <p class="pdp__shipping-note label-sm" style="text-align: center; color: var(--color-on-surface-variant);">
              {{ 'products.free_shipping' | t }}
            </p>
          </div>
        {% endform %}

        <div class="pdp__tags">
          {% for tag in product.tags limit: 4 %}
            <span class="chip">{{ tag }}</span>
          {% endfor %}
        </div>

        {% for block in section.blocks %}
          {% if block.type == 'accordion' %}
            <details class="pdp__accordion" {{ block.shopify_attributes }}>
              <summary class="pdp__accordion-title label-sm">
                {{ block.settings.heading }}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="m6 9 6 6 6-6"/></svg>
              </summary>
              <div class="pdp__accordion-content">
                {{ block.settings.content }}
              </div>
            </details>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .pdp__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--gutter);
    align-items: start;
  }
  @media (min-width: 1024px) {
    .pdp__grid {
      grid-template-columns: 7fr 5fr;
    }
  }
  .pdp__gallery {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .pdp__image-wrap--hero {
    grid-column: 1 / -1;
  }
  .pdp__image-wrap {
    overflow: hidden;
    background-color: var(--color-surface);
  }
  .pdp__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 4/5;
    transition: opacity 0.6s ease;
  }
  .pdp__image-wrap:hover .pdp__image {
    opacity: 0.95;
  }
  .pdp__details {
    position: sticky;
    top: 100px;
  }
  @media (max-width: 1023px) {
    .pdp__details { position: static; }
  }
  .pdp__meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }
  .pdp__rating {
    display: flex;
    gap: 2px;
  }
  .pdp__form {
    border-top: 1px solid color-mix(in srgb, var(--color-outline-variant) 30%, transparent);
    padding-top: 24px;
  }
  .pdp__variants {
    margin-bottom: 24px;
  }
  .pdp__option {
    margin-bottom: 16px;
  }
  .pdp__option label {
    display: block;
    margin-bottom: 8px;
    color: var(--color-on-surface-variant);
  }
  .pdp__option-select {
    width: 100%;
    border: 1px solid var(--color-outline-variant);
    padding: 12px 16px;
    background: transparent;
    font-size: 14px;
  }
  .pdp__add-section {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .pdp__quantity {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .pdp__quantity-controls {
    display: flex;
    align-items: center;
    border: 1px solid var(--color-outline-variant);
    padding: 8px 16px;
    gap: 24px;
  }
  .pdp__qty-btn {
    font-size: 18px;
    color: var(--color-on-background);
    transition: color 0.3s ease;
  }
  .pdp__qty-btn:hover { color: var(--color-primary); }
  .pdp__qty-input {
    width: 32px;
    text-align: center;
    border: none;
    background: transparent;
    font-size: 16px;
    -moz-appearance: textfield;
  }
  .pdp__qty-input::-webkit-outer-spin-button,
  .pdp__qty-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  .pdp__add-btn {
    width: 100%;
    padding: 20px;
  }
  .pdp__add-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .pdp__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 24px;
    margin-bottom: 24px;
  }
  .pdp__accordion {
    border-bottom: 1px solid color-mix(in srgb, var(--color-outline-variant) 30%, transparent);
  }
  .pdp__accordion-title {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 24px 0;
    cursor: pointer;
    list-style: none;
    color: var(--color-on-background);
  }
  .pdp__accordion-title::-webkit-details-marker { display: none; }
  .pdp__accordion[open] .pdp__accordion-title svg {
    transform: rotate(180deg);
  }
  .pdp__accordion-content {
    padding-bottom: 24px;
    color: var(--color-on-surface-variant);
    line-height: 1.7;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.product.name",
  "settings": [],
  "blocks": [
    {
      "type": "accordion",
      "name": "t:sections.product.accordion",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.product.accordion_heading",
          "default": "Ingredients"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "t:sections.product.accordion_content"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.product.name",
      "blocks": [
        {
          "type": "accordion",
          "settings": {
            "heading": "Ingredients"
          }
        },
        {
          "type": "accordion",
          "settings": {
            "heading": "Usage Instructions"
          }
        }
      ]
    }
  ]
}
{% endschema %}
