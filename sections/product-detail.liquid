<section class="product-detail section-gap">
  <div class="product-detail__inner container">
    <div class="product-detail__grid">
      {%- comment -%} Image Gallery — 7 columns {%- endcomment -%}
      <div class="product-detail__gallery">
        {% for image in product.images limit: 3 %}
          <div class="product-detail__image-wrap {% if forloop.first %}product-detail__image-wrap--hero{% endif %}">
            {% if forloop.first %}
              {{ image | image_url: width: 1200 | image_tag: class: 'product-detail__image', loading: 'eager' }}
            {% else %}
              {{ image | image_url: width: 800 | image_tag: class: 'product-detail__image', loading: 'lazy' }}
            {% endif %}
          </div>
        {% endfor %}
      </div>

      {%- comment -%} Product Details — 5 columns, sticky {%- endcomment -%}
      <div class="product-detail__details">
        <div class="product-detail__meta">
          {% if product.type != blank %}
            <span class="label-sm" style="color: var(--color-on-surface-variant);">{{ product.type }}</span>
          {% endif %}
          {% if product.metafields.reviews.rating.value != blank %}
            <div class="product-detail__rating">
              {% assign rating = product.metafields.reviews.rating.value.rating | round: 1 %}
              {% for i in (1..5) %}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="{% if i <= rating %}currentColor{% else %}none{% endif %}" stroke="currentColor" stroke-width="1.5" style="color: var(--color-on-surface-variant);">
                  <path d="m12 2 3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2Z"/>
                </svg>
              {% endfor %}
              {% if product.metafields.reviews.rating_count.value != blank %}
                <span class="label-sm" style="color: var(--color-on-surface-variant); margin-left: 4px;">
                  ({{ product.metafields.reviews.rating_count.value }})
                </span>
              {% endif %}
            </div>
          {% endif %}
        </div>

        <h1 class="display-lg" style="margin-bottom: 16px;">{{ product.title }}</h1>

        {% if product.description != blank %}
          <p class="body-lg" style="color: var(--color-on-surface-variant); max-width: 480px; margin-bottom: 24px;">
            {{ product.description | strip_html | truncate: 200 }}
          </p>
        {% endif %}

        <div class="product-detail__price">
          {{ product.selected_or_first_available_variant.price | money }}
          {% if product.compare_at_price > product.price %}
            <span class="product-detail__price-compare">
              {{ product.compare_at_price | money }}
            </span>
          {% endif %}
        </div>

        {% form 'product', product, class: 'product-detail__form' %}
          {% assign current_variant = product.selected_or_first_available_variant %}
          <input type="hidden" name="id" value="{{ current_variant.id }}">

          {% if product.variants.size > 1 %}
            <div class="product-detail__variants">
              {% for option in product.options_with_values %}
                <div class="product-detail__option">
                  <label class="label-sm" for="product-detail-option-{{ option.name | handleize }}">{{ option.name }}</label>
                  <select
                    id="product-detail-option-{{ option.name | handleize }}"
                    class="product-detail__option-select"
                    name="options[{{ option.name }}]"
                  >
                    {% for value in option.values %}
                      <option value="{{ value }}" {% if option.selected_value == value %}selected{% endif %}>
                        {{ value }}
                      </option>
                    {% endfor %}
                  </select>
                </div>
              {% endfor %}
            </div>
          {% endif %}

          <div class="product-detail__add-section">
            <div class="product-detail__quantity">
              <span class="label-sm" style="color: var(--color-on-surface-variant);">{{ 'products.quantity' | t }}</span>
              <div class="product-detail__quantity-controls">
                <button
                  type="button"
                  class="product-detail__qty-btn"
                  aria-label="{{ 'products.decrease' | t }}"
                  data-action="decrease"
                >-</button>
                <input
                  type="number"
                  name="quantity"
                  value="1"
                  min="1"
                  class="product-detail__qty-input"
                  aria-label="{{ 'products.quantity' | t }}"
                >
                <button
                  type="button"
                  class="product-detail__qty-btn"
                  aria-label="{{ 'products.increase' | t }}"
                  data-action="increase"
                >+</button>
              </div>
            </div>

            <button
              type="submit"
              class="btn-primary product-detail__add-btn"
              {% unless current_variant.available %}disabled{% endunless %}
            >
              {% if current_variant.available %}
                {{ 'products.add_to_bag' | t }}
              {% else %}
                {{ 'products.sold_out' | t }}
              {% endif %}
            </button>

            <p class="product-detail__shipping-note label-sm">
              {{ 'products.free_shipping' | t }}
            </p>
          </div>
        {% endform %}

        <div class="product-detail__chips">
          {% for tag in product.tags limit: 5 %}
            <span class="chip">{{ tag }}</span>
          {% endfor %}
        </div>

        {%- comment -%} Accordion sections {%- endcomment -%}
        {% for block in section.blocks %}
          {% if block.type == 'accordion' %}
            <details class="product-detail__accordion" {{ block.shopify_attributes }}>
              <summary class="product-detail__accordion-summary label-sm">
                {{ block.settings.heading }}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="m6 9 6 6 6-6"/>
                </svg>
              </summary>
              <div class="product-detail__accordion-content body-md">
                {{ block.settings.content }}
              </div>
            </details>
          {% endif %}
        {% endfor %}
      </div>
    </div>

    {%- comment -%} Reviews Section {%- endcomment -%}
    {% if product.metafields.reviews.rating.value != blank %}
      <div class="product-detail__reviews section-gap">
        <h2 class="headline-lg" style="margin-bottom: 32px;">{{ 'products.reviews_title' | t | default: 'Reviews' }}</h2>
        <div class="product-detail__reviews-summary">
          <div class="product-detail__reviews-score">
            <span class="display-lg">{{ product.metafields.reviews.rating.value.rating | round: 1 }}</span>
            <div>
              <div class="product-detail__rating">
                {% assign rating = product.metafields.reviews.rating.value.rating | round: 1 %}
                {% for i in (1..5) %}
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="{% if i <= rating %}currentColor{% else %}none{% endif %}" stroke="currentColor" stroke-width="1.5" style="color: var(--color-primary);">
                    <path d="m12 2 3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2Z"/>
                  </svg>
                {% endfor %}
              </div>
              {% if product.metafields.reviews.rating_count.value != blank %}
                <span class="body-md" style="color: var(--color-on-surface-variant);">
                  {{ product.metafields.reviews.rating_count.value }} {{ 'products.reviews_count' | t | default: 'reviews' }}
                </span>
              {% endif %}
            </div>
          </div>
        </div>
      </div>
    {% endif %}

    {%- comment -%} Complete Your Ritual — Related Products {%- endcomment -%}
    {% assign related_collection = product.collections.first %}
    {% if related_collection != blank %}
      <div class="product-detail__related section-gap">
        <div class="product-detail__related-header">
          <h2 class="display-md">{{ 'products.complete_ritual' | t | default: 'Complete Your Ritual' }}</h2>
        </div>
        <div class="product-detail__related-grid">
          {% for related_product in related_collection.products limit: 4 %}
            {% if related_product.id != product.id %}
              {% render 'product-card', product: related_product, show_quick_add: true %}
            {% endif %}
          {% endfor %}
        </div>
      </div>
    {% endif %}
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const quantityControls = document.querySelectorAll('.product-detail__quantity-controls');

    quantityControls.forEach(function (control) {
      const input = control.querySelector('.product-detail__qty-input');
      const decreaseBtn = control.querySelector('[data-action="decrease"]');
      const increaseBtn = control.querySelector('[data-action="increase"]');

      decreaseBtn.addEventListener('click', function () {
        const currentValue = parseInt(input.value, 10);
        if (currentValue > 1) {
          input.value = currentValue - 1;
        }
      });

      increaseBtn.addEventListener('click', function () {
        const currentValue = parseInt(input.value, 10);
        input.value = currentValue + 1;
      });
    });
  });
</script>

{% stylesheet %}
  .product-detail__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--gutter);
    align-items: start;
  }

  @media (min-width: 1024px) {
    .product-detail__grid {
      grid-template-columns: 7fr 5fr;
    }
  }

  /* Gallery */
  .product-detail__gallery {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .product-detail__image-wrap--hero {
    grid-column: 1 / -1;
  }

  .product-detail__image-wrap {
    overflow: hidden;
    background-color: var(--color-surface);
  }

  .product-detail__image-wrap--hero .product-detail__image {
    aspect-ratio: 4/5;
  }

  .product-detail__image-wrap:not(.product-detail__image-wrap--hero) .product-detail__image {
    aspect-ratio: 1/1;
  }

  .product-detail__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.6s ease;
  }

  .product-detail__image-wrap:hover .product-detail__image {
    opacity: 0.95;
  }

  /* Details panel */
  .product-detail__details {
    position: sticky;
    top: 128px;
  }

  @media (max-width: 1023px) {
    .product-detail__details {
      position: static;
    }
  }

  .product-detail__meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }

  .product-detail__rating {
    display: flex;
    align-items: center;
    gap: 2px;
  }

  .product-detail__price {
    font-size: 28px;
    font-weight: 500;
    color: var(--color-primary);
    margin-bottom: 40px;
  }

  .product-detail__price-compare {
    text-decoration: line-through;
    opacity: 0.5;
    font-size: 18px;
    margin-left: 8px;
  }

  /* Form */
  .product-detail__form {
    border-top: 1px solid color-mix(in srgb, var(--color-outline-variant) 30%, transparent);
    padding-top: 24px;
  }

  .product-detail__variants {
    margin-bottom: 24px;
  }

  .product-detail__option {
    margin-bottom: 16px;
  }

  .product-detail__option label {
    display: block;
    margin-bottom: 8px;
    color: var(--color-on-surface-variant);
  }

  .product-detail__option-select {
    width: 100%;
    border: 1px solid var(--color-outline-variant);
    padding: 12px 16px;
    background: transparent;
    font-size: 14px;
  }

  .product-detail__add-section {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .product-detail__quantity {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .product-detail__quantity-controls {
    display: flex;
    align-items: center;
    border: 1px solid var(--color-outline-variant);
    padding: 8px 16px;
    gap: 24px;
  }

  .product-detail__qty-btn {
    font-size: 18px;
    color: var(--color-on-background);
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px 8px;
    transition: color 0.3s ease;
  }

  .product-detail__qty-btn:hover {
    color: var(--color-primary);
  }

  .product-detail__qty-input {
    width: 32px;
    text-align: center;
    border: none;
    background: transparent;
    font-size: 16px;
    -moz-appearance: textfield;
  }

  .product-detail__qty-input::-webkit-outer-spin-button,
  .product-detail__qty-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .product-detail__add-btn {
    width: 100%;
    padding: 20px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .product-detail__add-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .product-detail__shipping-note {
    text-align: center;
    color: var(--color-on-surface-variant);
    margin: 0;
  }

  /* Chips */
  .product-detail__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 24px;
    margin-bottom: 24px;
  }

  /* Accordions */
  .product-detail__accordion {
    border-bottom: 1px solid color-mix(in srgb, var(--color-outline-variant) 30%, transparent);
  }

  .product-detail__accordion-summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 24px 0;
    cursor: pointer;
    list-style: none;
    color: var(--color-on-background);
  }

  .product-detail__accordion-summary::-webkit-details-marker {
    display: none;
  }

  .product-detail__accordion[open] .product-detail__accordion-summary svg {
    transform: rotate(180deg);
  }

  .product-detail__accordion-content {
    padding-bottom: 24px;
    color: var(--color-on-surface-variant);
    line-height: 1.7;
  }

  /* Reviews */
  .product-detail__reviews-summary {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .product-detail__reviews-score {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  /* Related Products */
  .product-detail__related-header {
    margin-bottom: 48px;
  }

  .product-detail__related-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--gutter);
  }

  @media (min-width: 768px) {
    .product-detail__related-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.product_detail.name",
  "tag": "section",
  "class": "main-product",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_reviews",
      "label": "t:sections.product_detail.show_reviews",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_related",
      "label": "t:sections.product_detail.show_related",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "accordion",
      "name": "t:sections.product_detail.accordion",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.product_detail.accordion_heading",
          "default": "Ingredients"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "t:sections.product_detail.accordion_content"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.product_detail.name",
      "blocks": [
        {
          "type": "accordion",
          "settings": {
            "heading": "Ingredients"
          }
        },
        {
          "type": "accordion",
          "settings": {
            "heading": "How to Use"
          }
        }
      ]
    }
  ]
}
{% endschema %}
