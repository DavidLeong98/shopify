<section class="product-detail section-gap">
  <div class="product-detail__inner container">
    <div class="product-detail__grid">
      {%- comment -%} Image Gallery — 7 columns {%- endcomment -%}
      <div class="product-detail__gallery">
        {% if product.images.size > 0 %}
          {% for image in product.images limit: 3 %}
            <div class="product-detail__image-wrap {% if forloop.first %}product-detail__image-wrap--hero{% endif %}">
              {% if forloop.first %}
                {{ image | image_url: width: 1200 | image_tag: class: 'product-detail__image', loading: 'eager', alt: product.title }}
              {% else %}
                {{ image | image_url: width: 800 | image_tag: class: 'product-detail__image', loading: 'lazy', alt: product.title }}
              {% endif %}
            </div>
          {% endfor %}
        {% else %}
          <div class="product-detail__image-wrap product-detail__image-wrap--hero">
            <svg class="pdp__placeholder" viewBox="0 0 480 600" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <rect width="480" height="600" fill="var(--color-surface-container-low)"/>
              <path d="M215 270 a25 25 0 1 1 50 0 a25 25 0 1 1 -50 0 M190 330 l40-30 30 20 40-50 40 60 v20 H190Z" fill="var(--color-outline-variant)" opacity="0.5"/>
            </svg>
          </div>
          <div class="product-detail__image-wrap">
            <svg class="pdp__placeholder" viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <rect width="400" height="400" fill="var(--color-surface-container-low)"/>
              <circle cx="200" cy="180" r="20" fill="var(--color-outline-variant)" opacity="0.5"/>
              <path d="M150 240 l30-20 20 15 30-40 30 45 v15 H150Z" fill="var(--color-outline-variant)" opacity="0.5"/>
            </svg>
          </div>
          <div class="product-detail__image-wrap">
            <svg class="pdp__placeholder" viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <rect width="400" height="400" fill="var(--color-surface-container-low)"/>
              <circle cx="200" cy="180" r="20" fill="var(--color-outline-variant)" opacity="0.5"/>
              <path d="M150 240 l30-20 20 15 30-40 30 45 v15 H150Z" fill="var(--color-outline-variant)" opacity="0.5"/>
            </svg>
          </div>
        {% endif %}
      </div>

      {%- comment -%} Product Details — 5 columns, sticky {%- endcomment -%}
      <div class="product-detail__details">
        <div class="product-detail__meta">
          {% if product.type != blank %}
            <span class="text-label" style="color: var(--color-tertiary);">{{ product.type }}</span>
          {% endif %}
          {% if product.metafields.reviews.rating.value != blank %}
            <div class="product-detail__rating">
              {% assign rating = product.metafields.reviews.rating.value.rating | round: 1 %}
              {% for i in (1..5) %}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="{% if i <= rating %}currentColor{% else %}none{% endif %}" stroke="currentColor" stroke-width="1.5" style="color: var(--color-tertiary);">
                  <path d="m12 2 3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2Z"/>
                </svg>
              {% endfor %}
              {% if product.metafields.reviews.rating_count.value != blank %}
                <span class="text-label" style="color: var(--color-on-surface-variant); margin-left: 4px;">
                  ({{ product.metafields.reviews.rating_count.value }})
                </span>
              {% endif %}
            </div>
          {% endif %}
        </div>

        <h1 class="text-display" style="margin-bottom: 16px;">{{ product.title }}</h1>

        {% if product.description != blank %}
          <p class="text-body-large" style="max-width: 480px; margin-bottom: 24px;">
            {{ product.description | strip_html | truncate: 200 }}
          </p>
        {% endif %}

        <div class="product-detail__price">
          {{ product.selected_or_first_available_variant.price | money }}
          {% if product.compare_at_price > product.price %}
            <span class="product-detail__price-compare">
              {{ product.compare_at_price | money }}
            </span>
          {% endif %}
        </div>

        {% form 'product', product, class: 'product-detail__form' %}
          {% assign current_variant = product.selected_or_first_available_variant %}
          <input type="hidden" name="id" value="{{ current_variant.id }}">

          {% if product.variants.size > 1 %}
            <div class="product-detail__variants">
              {% for option in product.options_with_values %}
                <div class="product-detail__option">
                  <label class="text-label" for="product-option-{{ option.name | handleize }}">{{ option.name }}</label>
                  <select
                    id="product-option-{{ option.name | handleize }}"
                    class="product-detail__option-select"
                    name="options[{{ option.name }}]"
                  >
                    {% for value in option.values %}
                      <option value="{{ value }}" {% if option.selected_value == value %}selected{% endif %}>
                        {{ value }}
                      </option>
                    {% endfor %}
                  </select>
                </div>
              {% endfor %}
            </div>
          {% endif %}

          <div class="product-detail__add-section">
            <div class="product-detail__quantity">
              <span class="text-label" style="color: var(--color-on-surface-variant);">{{ 'sections.product_detail.quantity' | t }}</span>
              <div class="product-detail__quantity-controls">
                <button
                  type="button"
                  class="product-detail__qty-btn"
                  aria-label="{{ 'sections.product_detail.decrease_quantity' | t }}"
                  data-action="decrease"
                >&minus;</button>
                <input
                  type="number"
                  name="quantity"
                  value="1"
                  min="1"
                  class="product-detail__qty-input"
                  aria-label="{{ 'sections.product_detail.quantity' | t }}"
                >
                <button
                  type="button"
                  class="product-detail__qty-btn"
                  aria-label="{{ 'sections.product_detail.increase_quantity' | t }}"
                  data-action="increase"
                >+</button>
              </div>
            </div>

            <button
              type="submit"
              class="btn btn--primary product-detail__add-btn"
              {% unless current_variant.available %}disabled{% endunless %}
            >
              {% if current_variant.available %}
                {{ 'sections.product_detail.add_to_bag' | t }}
              {% else %}
                {{ 'sections.product_detail.sold_out' | t }}
              {% endif %}
            </button>

            <p class="product-detail__shipping-note text-label">
              {{ 'sections.product_detail.free_shipping' | t }}
            </p>
          </div>
        {% endform %}

        {%- comment -%} Tag chips {%- endcomment -%}
        {% if product.tags.size > 0 %}
          <div class="product-detail__chips">
            {% for tag in product.tags limit: 5 %}
              <span class="product-detail__chip text-label">{{ tag }}</span>
            {% endfor %}
          </div>
        {% endif %}

        {%- comment -%} Accordion sections from blocks {%- endcomment -%}
        <div class="product-detail__accordions">
          {% for block in section.blocks %}
            {% if block.type == 'accordion' %}
              <details class="product-detail__accordion" {{ block.shopify_attributes }}>
                <summary class="product-detail__accordion-summary text-label">
                  {{ block.settings.heading }}
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="m6 9 6 6 6-6"/>
                  </svg>
                </summary>
                <div class="product-detail__accordion-content text-body">
                  {{ block.settings.content }}
                </div>
              </details>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var quantityControls = document.querySelectorAll('.product-detail__quantity-controls');

    quantityControls.forEach(function (control) {
      var input = control.querySelector('.product-detail__qty-input');
      var decreaseBtn = control.querySelector('[data-action="decrease"]');
      var increaseBtn = control.querySelector('[data-action="increase"]');

      decreaseBtn.addEventListener('click', function () {
        var currentValue = parseInt(input.value, 10);
        if (currentValue > 1) {
          input.value = currentValue - 1;
        }
      });

      increaseBtn.addEventListener('click', function () {
        var currentValue = parseInt(input.value, 10);
        input.value = currentValue + 1;
      });
    });

    /* Variant selector: update hidden id input when options change */
    var variantSelects = document.querySelectorAll('.product-detail__option-select');
    var hiddenIdInput = document.querySelector('.product-detail__form input[name="id"]');

    if (variantSelects.length > 0 && window.__productVariantsJSON) {
      variantSelects.forEach(function(select) {
        select.addEventListener('change', function() {
          var selectedOptions = [];
          variantSelects.forEach(function(s) {
            selectedOptions.push(s.value);
          });
          var variants = window.__productVariantsJSON;
          for (var i = 0; i < variants.length; i++) {
            var match = true;
            for (var j = 0; j < selectedOptions.length; j++) {
              if (variants[i].options[j] !== selectedOptions[j]) {
                match = false;
                break;
              }
            }
            if (match) {
              hiddenIdInput.value = variants[i].id;
              break;
            }
          }
        });
      });
    }
  });
</script>

{% if product.variants.size > 1 %}
  <script>
    window.__productVariantsJSON = {{ product.variants | json }};
  </script>
{% endif %}

{% stylesheet %}
  .product-detail__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-gutter);
    align-items: start;
  }

  @media (min-width: 1024px) {
    .product-detail__grid {
      grid-template-columns: 7fr 5fr;
    }
  }

  /* Gallery */
  .product-detail__gallery {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .product-detail__image-wrap--hero {
    grid-column: 1 / -1;
  }

  .product-detail__image-wrap {
    overflow: hidden;
    background-color: var(--color-surface-container-low);
  }

  .product-detail__image-wrap--hero .product-detail__image,
  .product-detail__image-wrap--hero .pdp__placeholder {
    aspect-ratio: 4/5;
  }

  .product-detail__image-wrap:not(.product-detail__image-wrap--hero) .product-detail__image,
  .product-detail__image-wrap:not(.product-detail__image-wrap--hero) .pdp__placeholder {
    aspect-ratio: 1/1;
  }

  .product-detail__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity var(--duration-slow) var(--easing-decelerate);
  }

  .product-detail__image-wrap:hover .product-detail__image {
    opacity: 0.95;
  }

  /* Details panel */
  .product-detail__details {
    position: sticky;
    top: 128px;
  }

  @media (max-width: 1023px) {
    .product-detail__details {
      position: static;
    }
  }

  .product-detail__meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }

  .product-detail__rating {
    display: flex;
    align-items: center;
    gap: 2px;
  }

  .product-detail__price {
    font-size: 28px;
    font-weight: 500;
    color: var(--color-primary);
    margin-bottom: 40px;
  }

  .product-detail__price-compare {
    text-decoration: line-through;
    opacity: 0.5;
    font-size: 18px;
    margin-left: 8px;
  }

  /* Form */
  .product-detail__form {
    border-top: 1px solid var(--color-outline-variant);
    padding-top: 24px;
  }

  .product-detail__variants {
    margin-bottom: 24px;
  }

  .product-detail__option {
    margin-bottom: 16px;
  }

  .product-detail__option label {
    display: block;
    margin-bottom: 8px;
    color: var(--color-on-surface-variant);
  }

  .product-detail__option-select {
    width: 100%;
    border: 1px solid var(--color-outline-variant);
    padding: 12px 16px;
    background: transparent;
    font-size: 14px;
  }

  .product-detail__add-section {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .product-detail__quantity {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .product-detail__quantity-controls {
    display: flex;
    align-items: center;
    border: 1px solid var(--color-outline-variant);
    padding: 8px 16px;
    gap: 24px;
  }

  .product-detail__qty-btn {
    font-size: 18px;
    color: var(--color-on-surface);
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px 8px;
    transition: color var(--duration-normal) var(--easing-standard);
  }

  .product-detail__qty-btn:hover {
    color: var(--color-primary);
  }

  .product-detail__qty-input {
    width: 32px;
    text-align: center;
    border: none;
    background: transparent;
    font-size: 16px;
    -moz-appearance: textfield;
  }

  .product-detail__qty-input::-webkit-outer-spin-button,
  .product-detail__qty-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .product-detail__add-btn {
    width: 100%;
    padding: 20px;
  }

  .product-detail__add-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .product-detail__shipping-note {
    text-align: center;
    color: var(--color-on-surface-variant);
    margin: 0;
  }

  /* Chips */
  .product-detail__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 24px;
    margin-bottom: 24px;
  }

  .product-detail__chip {
    background-color: var(--color-tertiary-container);
    color: var(--color-on-tertiary-container);
    padding: 4px 12px;
    font-size: 10px;
    letter-spacing: 0.05em;
  }

  /* Accordions */
  .product-detail__accordions {
    border-top: 1px solid var(--color-outline-variant);
  }

  .product-detail__accordion {
    border-bottom: 1px solid var(--color-outline-variant);
  }

  .product-detail__accordion-summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 24px 0;
    cursor: pointer;
    list-style: none;
    color: var(--color-on-surface);
  }

  .product-detail__accordion-summary::-webkit-details-marker {
    display: none;
  }

  .product-detail__accordion-summary svg {
    transition: transform var(--duration-normal) var(--easing-standard);
  }

  .product-detail__accordion[open] .product-detail__accordion-summary svg {
    transform: rotate(180deg);
  }

  .product-detail__accordion-content {
    padding-bottom: 24px;
    color: var(--color-on-surface-variant);
    line-height: 1.7;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Product Detail",
  "tag": "section",
  "class": "main-product",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_reviews",
      "label": "Show reviews section",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_related",
      "label": "Show related products",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "accordion",
      "name": "Accordion",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Ingredients"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Detail",
      "blocks": [
        {
          "type": "accordion",
          "settings": {
            "heading": "Ingredients"
          }
        },
        {
          "type": "accordion",
          "settings": {
            "heading": "Usage Instructions"
          }
        }
      ]
    }
  ]
}
{% endschema %}
