<section class="cart-page section-gap">
  <div class="cart-page__inner container">
    {% if cart.item_count == 0 %}
      <div class="cart-page__empty">
        <h1 class="text-display" style="margin-bottom: 24px;">{{ 'cart.title' | t }}</h1>
        <p class="text-body-large" style="color: var(--color-on-surface-variant); margin-bottom: 40px;">{{ 'cart.empty' | t }}</p>
        <a href="{{ routes.collections_url }}" class="btn btn--primary">{{ 'cart.continue_shopping' | t }}</a>
      </div>
    {% else %}
      <h1 class="text-display" style="color: var(--color-primary); margin-bottom: 48px;">{{ 'cart.title' | t }}</h1>
      <div class="cart-page__layout">
        <div class="cart-page__items">
          <form action="{{ routes.cart_url }}" method="post" id="cart-form">
            {% for item in cart.items %}
              <div class="cart-item">
                <div class="cart-item__image-wrap">
                  {% if item.image != blank %}
                    <a href="{{ item.url }}">
                      {{ item.image | image_url: width: 200, height: 200 | image_tag: class: 'cart-item__image', loading: 'lazy' }}
                    </a>
                  {% endif %}
                </div>
                <div class="cart-item__details">
                  <div class="cart-item__info">
                    <h3 class="text-headline" style="color: var(--color-primary);">
                      <a href="{{ item.url }}">{{ item.product.title }}</a>
                    </h3>
                    {% if item.variant.title != 'Default Title' %}
                      <p style="color: var(--color-on-surface-variant); font-size: 14px;">{{ item.variant.title }}</p>
                    {% endif %}
                  </div>
                  <div class="cart-item__actions">
                    <div class="cart-item__quantity">
                      <button type="button" class="cart-item__qty-btn" aria-label="{{ 'products.decrease' | t }}" onclick="this.nextElementSibling.stepDown(); this.closest('form').submit()">-</button>
                      <input type="number" name="updates[]" value="{{ item.quantity }}" min="0" class="cart-item__qty-input" aria-label="{{ 'products.quantity' | t }}">
                      <button type="button" class="cart-item__qty-btn" aria-label="{{ 'products.increase' | t }}" onclick="this.previousElementSibling.stepUp(); this.closest('form').submit()">+</button>
                    </div>
                    <span class="cart-item__price" style="font-weight: 500; color: var(--color-primary);">{{ item.line_price | money }}</span>
                  </div>
                </div>
                <a href="{{ item.url_to_remove }}" class="cart-item__remove" aria-label="{{ 'cart.remove' | t }}">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 6 6 18M6 6l12 12"/></svg>
                </a>
              </div>
            {% endfor %}
          </form>
        </div>

        <div class="cart-page__summary">
          <h3 class="text-headline" style="color: var(--color-primary); margin-bottom: 32px;">{{ 'cart.summary' | t }}</h3>
          <div class="cart-page__totals">
            <div class="cart-page__total-row">
              <span style="color: var(--color-on-surface-variant);">{{ 'cart.subtotal' | t }}</span>
              <span style="color: var(--color-primary); font-weight: 500;">{{ cart.total_price | money }}</span>
            </div>
            <div class="cart-page__total-row">
              <span style="color: var(--color-on-surface-variant);">{{ 'cart.shipping' | t }}</span>
              <span style="color: var(--color-on-surface-variant); font-style: italic;">{{ 'cart.shipping_calculated' | t }}</span>
            </div>
          </div>
          <div class="cart-page__grand-total">
            <span class="text-headline" style="color: var(--color-primary);">{{ 'cart.total' | t }}</span>
            <span class="text-display" style="font-size: 32px; color: var(--color-primary);">{{ cart.total_price | money }}</span>
          </div>
          <form action="{{ routes.cart_url }}" method="post">
            <button type="submit" name="checkout" class="btn btn--primary cart-page__checkout-btn">
              {{ 'cart.checkout' | t }} — {{ cart.total_price | money }}
            </button>
          </form>
          <a href="{{ routes.collections_url }}" class="cart-page__continue text-label">{{ 'cart.continue_shopping' | t }}</a>
        </div>
      </div>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .cart-page__empty {
    text-align: center;
    padding: 80px 0;
  }
  .cart-page__layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
  }
  @media (min-width: 1024px) {
    .cart-page__layout {
      grid-template-columns: 1fr 400px;
    }
  }
  .cart-item {
    display: flex;
    gap: 24px;
    padding: 32px 0;
    border-bottom: 1px solid color-mix(in srgb, var(--color-outline-variant) 30%, transparent);
    position: relative;
  }
  .cart-item__image-wrap {
    width: 96px;
    height: 96px;
    flex-shrink: 0;
    background-color: var(--color-surface);
  }
  .cart-item__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .cart-item__details {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }
  .cart-item__actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 16px;
  }
  .cart-item__quantity {
    display: flex;
    align-items: center;
    border: 1px solid var(--color-outline-variant);
    padding: 4px 12px;
    gap: 16px;
  }
  .cart-item__qty-btn {
    font-size: 16px;
    color: var(--color-on-background);
  }
  .cart-item__qty-btn:hover { color: var(--color-primary); }
  .cart-item__qty-input {
    width: 24px;
    text-align: center;
    border: none;
    background: transparent;
    font-size: 14px;
    -moz-appearance: textfield;
  }
  .cart-item__qty-input::-webkit-outer-spin-button,
  .cart-item__qty-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
  }
  .cart-item__remove {
    position: absolute;
    top: 32px;
    right: 0;
    color: var(--color-outline);
    transition: color 0.3s ease;
  }
  .cart-item__remove:hover { color: var(--color-primary); }
  .cart-page__summary {
    background: var(--color-surface);
    padding: 40px;
    border: 1px solid color-mix(in srgb, var(--color-outline-variant) 20%, transparent);
    position: sticky;
    top: 100px;
    align-self: start;
  }
  .cart-page__totals {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding-bottom: 24px;
    border-bottom: 1px solid color-mix(in srgb, var(--color-outline-variant) 30%, transparent);
  }
  .cart-page__total-row {
    display: flex;
    justify-content: space-between;
    font-size: 14px;
  }
  .cart-page__grand-total {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    padding-top: 24px;
    margin-bottom: 32px;
  }
  .cart-page__checkout-btn {
    width: 100%;
    padding: 20px;
    margin-bottom: 16px;
  }
  .cart-page__continue {
    display: block;
    text-align: center;
    color: var(--color-on-surface-variant);
    border-bottom: 1px solid var(--color-outline-variant);
    padding-bottom: 4px;
    width: fit-content;
    margin-inline: auto;
  }
  .cart-page__continue:hover { color: var(--color-primary); }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.cart.name",
  "settings": []
}
{% endschema %}
