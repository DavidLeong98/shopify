<footer class="footer section-gap" role="contentinfo">
  <div class="footer__inner container">
    <div class="footer__grid">
      <div class="footer__brand">
        <a href="{{ routes.root_url }}" class="footer__logo display-lg">{{ shop.name }}</a>
        <p class="footer__tagline">{{ section.settings.tagline }}</p>
        {% if section.settings.show_newsletter %}
          {% form 'customer', class: 'footer__newsletter' %}
            <label for="footer-email" class="visually-hidden">{{ 'footer.email_label' | t }}</label>
            <input
              type="email"
              id="footer-email"
              name="contact[email]"
              placeholder="{{ 'footer.email_placeholder' | t }}"
              class="footer__newsletter-input"
              required
            >
            <button type="submit" class="footer__newsletter-btn" aria-label="{{ 'footer.subscribe' | t }}">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M5 12h14m-7-7 7 7-7 7"/>
              </svg>
            </button>
          {% endform %}
        {% endif %}
      </div>
      {% for block in section.blocks %}
        <div class="footer__column" {{ block.shopify_attributes }}>
          <h4 class="footer__heading label-sm">{{ block.settings.heading }}</h4>
          <ul class="footer__links" role="list">
            {% for link in block.settings.menu.links %}
              <li>
                <a href="{{ link.url }}" class="footer__link">{{ link.title }}</a>
              </li>
            {% endfor %}
          </ul>
        </div>
      {% endfor %}
    </div>
    <div class="footer__bottom">
      <p class="footer__copyright label-sm">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ 'footer.rights' | t }}</p>
      {% if section.settings.show_payment_icons %}
        <div class="footer__payment">
          {% for type in shop.enabled_payment_types %}
            {{ type | payment_type_svg_tag }}
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</footer>

{% stylesheet %}
  .footer {
    background-color: var(--color-surface);
  }
  .footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--gutter);
  }
  @media (min-width: 768px) {
    .footer__grid {
      grid-template-columns: 1.5fr repeat(3, 1fr);
    }
  }
  .footer__logo {
    font-size: clamp(24px, 3vw, 48px);
    color: var(--color-primary);
    display: block;
    margin-bottom: 24px;
  }
  .footer__tagline {
    color: var(--color-on-surface-variant);
    margin-bottom: 32px;
    max-width: 280px;
  }
  .footer__newsletter {
    display: flex;
    border-bottom: 1px solid var(--color-outline);
    padding-bottom: 8px;
  }
  .footer__newsletter-input {
    flex: 1;
    border: none;
    background: transparent;
    font-size: 14px;
    padding: 8px 0;
    color: var(--color-on-background);
  }
  .footer__newsletter-input::placeholder {
    color: var(--color-outline);
  }
  .footer__newsletter-input:focus {
    outline: none;
  }
  .footer__newsletter-btn {
    color: var(--color-primary);
    padding: 8px;
  }
  .footer__heading {
    color: var(--color-primary);
    margin-bottom: 24px;
  }
  .footer__links {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .footer__link {
    color: var(--color-on-surface-variant);
    transition: color 0.3s ease;
  }
  .footer__link:hover {
    color: var(--color-primary);
  }
  .footer__bottom {
    margin-top: 80px;
    padding-top: 32px;
    border-top: 1px solid color-mix(in srgb, var(--color-outline-variant) 30%, transparent);
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
  }
  .footer__copyright {
    color: var(--color-on-surface-variant);
  }
  .footer__payment {
    display: flex;
    gap: 8px;
  }
  .footer__payment svg {
    width: 38px;
    height: 24px;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.footer.name",
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "t:sections.footer.tagline",
      "default": "Ethereal beauty through refined clinical science."
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "t:sections.footer.show_newsletter",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "t:sections.footer.show_payment_icons",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "menu_column",
      "name": "t:sections.footer.menu_column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.footer.column_heading",
          "default": "Shop"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "t:sections.footer.column_menu",
          "default": "footer"
        }
      ]
    }
  ]
}
{% endschema %}
