{%- comment -%}
  LUMINA Footer — brand column with newsletter, link columns via blocks, payment icons.
{%- endcomment -%}

<footer class="footer section-gap" role="contentinfo">
  <div class="footer__inner container">
    <div class="footer__grid">
      <!-- Brand column -->
      <div class="footer__brand">
        <a href="{{ routes.root_url }}" class="footer__logo">
          {{ section.settings.logo_text | default: shop.name }}
        </a>
        <p class="footer__tagline text-body">{{ section.settings.tagline }}</p>

        {%- if section.settings.show_newsletter -%}
          {%- form 'customer', class: 'footer__newsletter' -%}
            <label for="footer-email" class="visually-hidden">{{ 'general.newsletter.email_label' | t }}</label>
            <input
              type="email"
              id="footer-email"
              name="contact[email]"
              placeholder="{{ 'general.newsletter.email_placeholder' | t }}"
              class="footer__newsletter-input"
              autocomplete="email"
              required
            >
            <button type="submit" class="footer__newsletter-btn btn" aria-label="{{ 'general.newsletter.subscribe' | t }}">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </button>
          {%- endform -%}
        {%- endif -%}
      </div>

      <!-- Link columns from blocks -->
      {%- for block in section.blocks -%}
        {%- if block.type == 'menu_column' -%}
          <div class="footer__column" {{ block.shopify_attributes }}>
            <h4 class="footer__heading text-label">{{ block.settings.heading }}</h4>
            <ul class="footer__links" role="list">
              {%- for link in block.settings.menu.links -%}
                <li>
                  <a href="{{ link.url }}" class="footer__link">{{ link.title }}</a>
                </li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <!-- Bottom bar -->
    <div class="footer__bottom">
      <p class="footer__copyright">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ 'sections.footer.copyright' | t }}
      </p>

      {%- if section.settings.show_payment_icons -%}
        <div class="footer__payment">
          {%- for type in shop.enabled_payment_types -%}
            {{ type | payment_type_svg_tag }}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</footer>

{% stylesheet %}
  .footer {
    background-color: var(--color-surface-container-low);
  }
  .footer__inner {
    max-width: var(--space-container-max);
    margin: 0 auto;
  }
  .footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: calc(var(--space-unit) * 6);
  }
  @media (min-width: 768px) {
    .footer__grid {
      grid-template-columns: 1.5fr repeat(3, 1fr);
      gap: var(--space-gutter);
    }
  }

  /* Brand column */
  .footer__logo {
    font-family: var(--font-heading);
    font-size: clamp(24px, 3vw, 36px);
    font-weight: 500;
    letter-spacing: -0.02em;
    color: var(--color-on-surface);
    display: block;
    margin-bottom: calc(var(--space-unit) * 2.5);
  }
  .footer__tagline {
    margin-bottom: calc(var(--space-unit) * 4);
    max-width: 280px;
    color: var(--color-on-surface-variant);
  }

  /* Newsletter */
  .footer__newsletter {
    display: flex;
    align-items: center;
    border-bottom: 1px solid var(--color-outline);
    padding-bottom: 4px;
    max-width: 280px;
  }
  .footer__newsletter-input {
    flex: 1;
    border: none;
    background: transparent;
    font-family: var(--font-body);
    font-size: 14px;
    padding: calc(var(--space-unit) * 1) 0;
    color: var(--color-on-surface);
  }
  .footer__newsletter-input::placeholder {
    color: var(--color-outline);
  }
  .footer__newsletter-input:focus {
    outline: none;
  }
  .footer__newsletter-btn {
    padding: calc(var(--space-unit) * 1);
    color: var(--color-primary);
    border: none;
    background: none;
    transition: opacity var(--duration-normal) var(--easing-standard);
  }
  .footer__newsletter-btn:hover {
    opacity: 0.7;
  }

  /* Link columns */
  .footer__heading {
    margin-bottom: calc(var(--space-unit) * 3);
    color: var(--color-on-surface);
  }
  .footer__links {
    display: flex;
    flex-direction: column;
    gap: calc(var(--space-unit) * 2);
  }
  .footer__link {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--color-on-surface-variant);
    transition: color var(--duration-normal) var(--easing-standard);
  }
  .footer__link:hover {
    color: var(--color-primary);
  }

  /* Bottom bar */
  .footer__bottom {
    margin-top: calc(var(--space-unit) * 10);
    padding-top: calc(var(--space-unit) * 4);
    border-top: 1px solid var(--color-outline-variant);
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: calc(var(--space-unit) * 2);
  }
  .footer__copyright {
    font-family: var(--font-body);
    font-size: var(--text-label-size);
    letter-spacing: 0.02em;
    color: var(--color-on-surface-variant);
  }

  /* Payment icons */
  .footer__payment {
    display: flex;
    gap: calc(var(--space-unit) * 1);
    align-items: center;
  }
  .footer__payment svg {
    width: 38px;
    height: 24px;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.footer.name",
  "class": "section-footer",
  "settings": [
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text",
      "default": "LUMINA"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "t:sections.footer.tagline",
      "default": "Ethereal beauty through refined clinical science."
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "t:sections.footer.show_newsletter",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "t:sections.footer.show_payment_icons",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "menu_column",
      "name": "t:sections.footer.menu_column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.footer.column_heading",
          "default": "Shop"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "t:sections.footer.column_menu",
          "default": "footer"
        }
      ]
    }
  ],
  "max_blocks": 4
}
{% endschema %}
