{%- comment -%}
  LUMINA Header — sticky glassmorphism nav with scroll hide/show, mobile drawer.
  Uses Material Symbols Outlined for icons.
{%- endcomment -%}

<header class="header" role="banner" id="site-header">
  <a class="visually-hidden" href="#main">{{ 'accessibility.skip_to_content' | t }}</a>

  <nav class="header__inner container" aria-label="{{ 'sections.header.navigation' | t }}">
    <div class="header__left">
      <a href="{{ routes.root_url }}" class="header__logo text-headline">
        {{ section.settings.logo_text | default: shop.name }}
      </a>
      <ul class="header__nav" role="list">
        {%- for link in section.settings.menu.links -%}
          <li>
            <a
              href="{{ link.url }}"
              class="header__nav-link text-label{% if link.active %} header__nav-link--active{% endif %}"
              {% if link.current %}aria-current="page"{% endif %}
            >
              {{ link.title }}
            </a>
          </li>
        {%- endfor -%}
      </ul>
    </div>

    <div class="header__actions">
      <a href="{{ routes.search_url }}" class="header__icon" aria-label="{{ 'sections.header.search' | t }}">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
        </svg>
      </a>
      {%- if shop.customer_accounts_enabled -%}
        <a href="{{ routes.account_url }}" class="header__icon" aria-label="{{ 'sections.header.account' | t }}">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="8" r="4"/><path d="M4 21c0-4.4 3.6-8 8-8s8 3.6 8 8"/>
          </svg>
        </a>
      {%- endif -%}
      <a href="{{ routes.cart_url }}" class="header__icon header__cart" aria-label="{{ 'sections.header.cart' | t }}{% if cart.item_count > 0 %} — {{ 'accessibility.cart_count' | t: count: cart.item_count }}{% endif %}">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        {%- if cart.item_count > 0 -%}
          <span class="header__cart-count" aria-hidden="true">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>
      <button
        class="header__menu-toggle"
        aria-label="{{ 'accessibility.menu_toggle' | t }}"
        aria-expanded="false"
        aria-controls="header-mobile-nav"
      >
        <svg class="header__menu-icon--open" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
          <path d="M4 7h16M4 12h16M4 17h16"/>
        </svg>
        <svg class="header__menu-icon--close" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
          <path d="M18 6 6 18M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile navigation drawer -->
  <div class="header__mobile-nav" id="header-mobile-nav" aria-hidden="true">
    <ul class="header__mobile-list" role="list">
      {%- for link in section.settings.menu.links -%}
        <li>
          <a
            href="{{ link.url }}"
            class="header__mobile-link{% if link.active %} header__mobile-link--active{% endif %}"
            {% if link.current %}aria-current="page"{% endif %}
          >
            {{ link.title }}
          </a>
        </li>
      {%- endfor -%}
    </ul>
  </div>
</header>

<script>
  (function() {
    var header = document.getElementById('site-header');
    var toggle = header.querySelector('.header__menu-toggle');
    var mobileNav = document.getElementById('header-mobile-nav');
    var lastScrollY = 0;
    var ticking = false;

    function onScroll() {
      var currentScrollY = window.scrollY;
      if (currentScrollY > lastScrollY && currentScrollY > 80) {
        header.classList.add('header--hidden');
      } else {
        header.classList.remove('header--hidden');
      }
      lastScrollY = currentScrollY;
      ticking = false;
    }

    window.addEventListener('scroll', function() {
      if (!ticking) {
        window.requestAnimationFrame(onScroll);
        ticking = true;
      }
    }, { passive: true });

    toggle.addEventListener('click', function() {
      var expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      mobileNav.setAttribute('aria-hidden', String(expanded));
      header.classList.toggle('header--mobile-open', !expanded);
    });
  })();
</script>

{% stylesheet %}
  /* --- Header: Sticky Glassmorphism --- */
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background-color: color-mix(in srgb, var(--color-background) 80%, transparent);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid color-mix(in srgb, var(--color-outline-variant) 30%, transparent);
    transition: transform var(--duration-normal) var(--easing-standard);
  }
  .header--hidden {
    transform: translateY(-100%);
  }
  .header__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-block: calc(var(--space-unit) * 2);
  }
  .header__left {
    display: flex;
    align-items: center;
    gap: calc(var(--space-unit) * 5);
  }

  /* Logo */
  .header__logo {
    font-family: var(--font-heading);
    font-size: clamp(22px, 2.5vw, 32px);
    font-weight: 500;
    letter-spacing: -0.02em;
    color: var(--color-on-surface);
    line-height: 1;
  }

  /* Desktop nav */
  .header__nav {
    display: none;
    gap: calc(var(--space-unit) * 4);
  }
  @media (min-width: 768px) {
    .header__nav {
      display: flex;
    }
  }
  .header__nav-link {
    font-size: var(--text-label-size);
    font-weight: var(--text-label-weight);
    letter-spacing: var(--text-label-letter-spacing);
    text-transform: uppercase;
    color: var(--color-on-surface-variant);
    padding-bottom: 4px;
    border-bottom: 1.5px solid transparent;
    transition: color var(--duration-normal) var(--easing-standard),
                border-color var(--duration-normal) var(--easing-standard);
  }
  .header__nav-link:hover {
    color: var(--color-primary);
  }
  .header__nav-link--active {
    color: var(--color-on-surface);
    font-weight: 700;
    border-bottom-color: var(--color-on-surface);
  }

  /* Actions */
  .header__actions {
    display: flex;
    align-items: center;
    gap: calc(var(--space-unit) * 2.5);
  }
  .header__icon {
    color: var(--color-on-surface);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity var(--duration-normal) var(--easing-standard);
  }
  .header__icon:hover {
    opacity: 0.6;
  }
  .header__cart {
    position: relative;
  }
  .header__cart-count {
    position: absolute;
    top: -5px;
    right: -7px;
    min-width: 16px;
    height: 16px;
    padding: 0 4px;
    background-color: var(--color-primary);
    color: var(--color-on-primary);
    font-family: var(--font-body);
    font-size: 9px;
    font-weight: 600;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }

  /* Mobile menu toggle */
  .header__menu-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-on-surface);
  }
  .header__menu-icon--close {
    display: none;
  }
  .header--mobile-open .header__menu-icon--open {
    display: none;
  }
  .header--mobile-open .header__menu-icon--close {
    display: block;
  }
  @media (min-width: 768px) {
    .header__menu-toggle {
      display: none;
    }
  }

  /* Mobile nav drawer */
  .header__mobile-nav {
    display: none;
    background-color: color-mix(in srgb, var(--color-background) 95%, transparent);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    padding: calc(var(--space-unit) * 3) var(--space-margin-mobile);
    border-top: 1px solid color-mix(in srgb, var(--color-outline-variant) 30%, transparent);
  }
  .header--mobile-open .header__mobile-nav {
    display: block;
  }
  @media (min-width: 768px) {
    .header__mobile-nav {
      display: none !important;
    }
  }
  .header__mobile-list {
    display: flex;
    flex-direction: column;
    gap: calc(var(--space-unit) * 2.5);
  }
  .header__mobile-link {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-on-surface-variant);
    transition: color var(--duration-normal) var(--easing-standard);
  }
  .header__mobile-link:hover,
  .header__mobile-link--active {
    color: var(--color-on-surface);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.header.name",
  "class": "section-header",
  "settings": [
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text",
      "default": "LUMINA"
    },
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "t:sections.header.menu"
    }
  ]
}
{% endschema %}
