<section class="featured-products section-gap">
  <div class="featured-products__inner container">
    <div class="featured-products__header">
      <div>
        {% if section.settings.eyebrow != blank %}
          <span class="text-label" style="color: var(--color-primary); display: block; margin-bottom: 8px;">{{ section.settings.eyebrow }}</span>
        {% endif %}
        <h2 class="text-display">{{ section.settings.heading }}</h2>
      </div>
      {% if section.settings.link_label != blank %}
        <a href="{{ section.settings.link_url }}" class="featured-products__view-all text-label">{{ section.settings.link_label }}</a>
      {% endif %}
    </div>
    <div class="featured-products__slider">
      {% for product in section.settings.collection.products limit: section.settings.products_to_show %}
        <div class="product-card">
          <div class="product-card__image-wrap">
            {% if product.featured_image != blank %}
              {{ product.featured_image | image_url: width: 600, height: 800 | image_tag: class: 'product-card__image', loading: 'lazy' }}
            {% else %}
              {{ 'product-1' | placeholder_svg_tag: 'product-card__image product-card__placeholder' }}
            {% endif %}
            {% if product.metafields.custom.badge != blank %}
              <span class="product-card__badge text-label">{{ product.metafields.custom.badge }}</span>
            {% endif %}
            <a href="{{ product.url }}" class="product-card__quick-add">
              {{ 'products.quick_add' | t }} — {{ product.price | money }}
            </a>
          </div>
          <h4 class="text-headline" style="margin-bottom: 4px;">
            <a href="{{ product.url }}">{{ product.title }}</a>
          </h4>
          <p style="color: var(--color-on-surface-variant); margin-bottom: 8px;">{{ product.metafields.descriptors.subtitle.value | default: product.vendor }}</p>
          <div class="featured-products__tags">
            {% for tag in product.tags limit: 3 %}
              <span class="chip">{{ tag }}</span>
            {% endfor %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .featured-products__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 64px;
  }
  .featured-products__view-all {
    color: var(--color-primary);
    border-bottom: 1px solid var(--color-primary);
    padding-bottom: 4px;
    transition: opacity 0.3s ease;
  }
  .featured-products__view-all:hover {
    opacity: 0.6;
  }
  .featured-products__slider {
    display: flex;
    gap: var(--gutter);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding-bottom: 32px;
    scrollbar-width: none;
  }
  .featured-products__slider::-webkit-scrollbar {
    display: none;
  }
  .featured-products__slider .product-card {
    min-width: 320px;
    scroll-snap-align: start;
    flex-shrink: 0;
  }
  @media (min-width: 768px) {
    .featured-products__slider .product-card {
      min-width: 400px;
    }
  }
  .product-card__badge {
    position: absolute;
    top: 16px;
    left: 16px;
    background-color: color-mix(in srgb, white 80%, transparent);
    backdrop-filter: blur(4px);
    padding: 4px 12px;
  }
  .featured-products__tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.featured_products.name",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.featured_products.eyebrow",
      "default": "Curated for You"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.featured_products.heading",
      "default": "Best Sellers"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "t:sections.featured_products.collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "label": "t:sections.featured_products.products_to_show",
      "default": 6
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "t:sections.featured_products.link_label",
      "default": "View All Products"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "t:sections.featured_products.link_url"
    }
  ],
  "presets": [
    {
      "name": "t:sections.featured_products.name"
    }
  ]
}
{% endschema %}
