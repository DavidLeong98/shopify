<section class="rituals section-gap" style="background-color: var(--color-surface-container-low);">
  <div class="rituals__inner container">
    <div class="rituals__header">
      {% if section.settings.eyebrow != blank %}
        <span class="rituals__eyebrow text-label">{{ section.settings.eyebrow }}</span>
      {% endif %}
      <h2 class="text-display">{{ section.settings.heading }}</h2>
      {% if section.settings.subheading != blank %}
        <p class="rituals__subheading text-body-large">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>
    <div class="rituals__grid grid--2">
      {% for block in section.blocks %}
        <div class="ritual-card" {{ block.shopify_attributes }}>
          <div class="ritual-card__media">
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 800 | image_tag: class: 'ritual-card__image', loading: 'lazy' }}
            {% elsif block.settings.image_url != blank %}
              <img src="{{ block.settings.image_url }}" alt="{{ block.settings.heading | escape }}" class="ritual-card__image" loading="lazy" width="800" height="450">
            {% else %}
              {{ 'collection-1' | placeholder_svg_tag: 'ritual-card__placeholder' }}
            {% endif %}
          </div>
          <div class="ritual-card__overlay">
            <h3 class="text-headline ritual-card__overlay-title">{{ block.settings.heading }}</h3>
            <p class="ritual-card__overlay-desc text-body">{{ block.settings.description }}</p>
            {% if block.settings.button_label != blank %}
              <a href="{{ block.settings.button_link }}" class="btn btn--secondary ritual-card__btn">
                {{ block.settings.button_label }}
              </a>
            {% endif %}
          </div>
          <div class="ritual-card__title">
            <h3 class="text-headline">{{ block.settings.heading }}</h3>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .rituals__header {
    text-align: center;
    margin-bottom: 64px;
  }
  .rituals__eyebrow {
    display: block;
    color: var(--color-primary);
    margin-bottom: 16px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }
  .rituals__subheading {
    color: var(--color-on-surface-variant);
    margin-top: 24px;
    max-width: 640px;
    margin-inline: auto;
    line-height: 1.7;
  }
  .rituals__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-gutter);
  }
  @media (min-width: 768px) {
    .rituals__grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  .ritual-card {
    position: relative;
    overflow: hidden;
    aspect-ratio: 16/9;
    background-color: var(--color-surface);
    cursor: pointer;
  }
  .ritual-card__media {
    position: absolute;
    inset: 0;
  }
  .ritual-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.85;
    transition: transform var(--duration-slow) var(--easing-decelerate);
  }
  .ritual-card:hover .ritual-card__image {
    transform: scale(1.08);
  }
  .ritual-card__placeholder {
    width: 100%;
    height: 100%;
    background-color: var(--color-surface-container);
    fill: var(--color-outline-variant);
  }
  .ritual-card__overlay {
    position: absolute;
    inset: 0;
    background-color: color-mix(in srgb, var(--color-primary) 25%, transparent);
    backdrop-filter: blur(6px);
    opacity: 0;
    transition: opacity var(--duration-slow) var(--easing-standard);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 48px;
    text-align: center;
    color: white;
  }
  .ritual-card:hover .ritual-card__overlay {
    opacity: 1;
  }
  .ritual-card__overlay-title {
    margin-bottom: 16px;
    color: white;
  }
  .ritual-card__overlay-desc {
    margin-bottom: 24px;
    max-width: 320px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.9);
  }
  .ritual-card__btn {
    border-color: white;
    color: white;
  }
  .ritual-card__btn:hover {
    background-color: white;
    color: var(--color-primary);
    border-color: white;
  }
  .ritual-card__title {
    position: absolute;
    bottom: 24px;
    left: 24px;
    color: white;
    transition: opacity var(--duration-normal) var(--easing-standard);
    text-shadow: 0 1px 4px color-mix(in srgb, black 40%, transparent);
  }
  .ritual-card:hover .ritual-card__title {
    opacity: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.rituals.name",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.rituals.eyebrow",
      "default": "The Art of Care"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.rituals.heading",
      "default": "The Lumina Rituals"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "t:sections.rituals.subheading",
      "default": "Synergistic product pairings designed to elevate your daily routine into a meditative self-care experience."
    }
  ],
  "blocks": [
    {
      "type": "ritual",
      "name": "t:sections.rituals.ritual",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.rituals.image"
        },
        {
          "type": "url",
          "id": "image_url",
          "label": "t:sections.rituals.image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.rituals.ritual_heading",
          "default": "The Morning Awakening"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "t:sections.rituals.description",
          "default": "Cleanse, Hydrate, and Protect for an all-day luminous glow."
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "t:sections.rituals.button_label",
          "default": "Shop Ritual"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "t:sections.rituals.button_link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.rituals.name",
      "blocks": [
        {
          "type": "ritual",
          "settings": {
            "heading": "The Morning Awakening",
            "description": "Cleanse, Hydrate, and Protect for an all-day luminous glow.",
            "button_label": "Shop Ritual — $180"
          }
        },
        {
          "type": "ritual",
          "settings": {
            "heading": "The Evening Repose",
            "description": "Detoxify and repair while you rest with our signature night set.",
            "button_label": "Shop Ritual — $225"
          }
        }
      ]
    }
  ]
}
{% endschema %}
